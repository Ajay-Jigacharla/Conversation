# ── SharedLLM Gateway ────────────────────────────────────────────────
# Get your virtual key at https://sharedllm.com → API Keys
SHAREDLLM_KEY=sk-sharedllm-YOUR_KEY

# ── Ollama (routed through SharedLLM) ────────────────────────────────
# SharedLLM proxies Ollama at /ollama — path /api/chat is appended automatically
OLLAMA_HOST=https://api.sharedllm.com/ollama
OLLAMA_MODEL=kimi-k2.7-code

# ── Whisper ASR ───────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large-v3
WHISPER_MODEL=tiny

# ── Kitten TTS ────────────────────────────────────────────────────────
KITTEN_MODEL=KittenML/kitten-tts-nano-0.8
# Available voices: expr-voice-2-f, bella, jasper, luna, bruno
KITTEN_VOICE=expr-voice-2-f

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
